CONST RETRY_LIMIT = 3

ENUM HTTPCODE
OK = 200
CREATED = 201
ACCEPTED
ENDENUM

DIM METHOD = METHOD_POST
IF METHOD = METHOD_POST THEN
    Resp.Status(HTTPCODE_CREATED)
    Io.WriteByte(RETRY_LIMIT)
    Io.WriteByte(HTTPCODE_OK)
    Io.WriteByte(HTTPCODE_CREATED)
    Io.WriteByte(STATUS_ACCEPTED)
ENDIF
