const RETRY_LIMIT = 3;

enum HttpCode {
    OK = 200,
    CREATED = 201,
    ACCEPTED
};

int method = METHOD_POST;
if (method == METHOD_POST) {
    Resp.Status(HttpCode.CREATED);
    Io.WriteByte(RETRY_LIMIT);
    Io.WriteByte(HTTPCODE_OK);
    Io.WriteByte(HTTPCODE_CREATED);
    Io.WriteByte(STATUS_ACCEPTED);
}
