// PSUnit: core arithmetic and the Assert.* assertion primitives (C frontend).
int a = 2 + 3;
Assert.Eq(a, 5);
Assert.True(a > 0);

int b = a * a;
Assert.Eq(b, 25);
Assert.Eq(b - a, 20);
Assert.True(b != a);

// Branch + loop: sum 1..5 = 15.
int total = 0;
for (i = 1; i <= 5; i = i + 1) {
  total = total + i;
}
Assert.Eq(total, 15);
